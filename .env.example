# ── Required ──
DISCORD_TOKEN=
CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Dashboard ──
DASHBOARD_PORT=3000
DASHBOARD_URL=http://localhost:3000
# Override for CSRF origin check (defaults to http://localhost:{PORT})
# DASHBOARD_ORIGIN=http://localhost:3000
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
SESSION_SECRET=

# ── Command Deployment ──
# Set GUILD_ID for instant guild-scoped commands (omit for global, takes up to 1h)
DEPLOY_COMMANDS=true
# GUILD_ID=

# ── Optional Features ──
GENIUS_API_KEY=
LOG_LEVEL=INFO
NODE_ENV=development
# UPGRADE_MODE=true

# ── Profanity Filter ──
# PROFANITY_LIST=badword1,badword2
# PROFANITY_EXTRA=extra1,extra2
