{
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-empty": "warn"
  },
  "overrides": [
    {
      "files": ["src/dashboard/public/**/*.js"],
      "env": {
        "browser": true,
        "node": false,
        "es2022": true
      }
    }
  ]
}
